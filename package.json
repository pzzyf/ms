{
  "name": "ms",
  "version": "1.0.0",
  "license": "ISC",
  "scripts": {
    "dev": "turbo-run dev",
    "format": "vsh lint --format",
    "lint": "vsh lint",
    "test:unit": "vitest run --dom",
    "check:type": "turbo run typecheck",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm -r run stub --if-present",
    "prepare": "is-ci || pnpm exec lefthook install",
    "catalog": "pnpm dlx codemod pnpm/catalog"
  },
  "devDependencies": {
    "@ms/commitlint-config": "workspace:*",
    "@ms/eslint-config": "workspace:*",
    "@ms/node-utils": "workspace:*",
    "@ms/prettier-config": "workspace:*",
    "@ms/tailwind-config": "workspace:*",
    "@ms/tsconfig": "workspace:*",
    "@ms/turbo-run": "workspace:*",
    "@ms/vite-config": "workspace:*",
    "@ms/vsh": "workspace:*",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "catalog:",
    "is-ci": "catalog:",
    "lefthook": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
