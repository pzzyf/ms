{
  "name": "ms",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.4",
  "license": "ISC",
  "scripts": {
    "dev": "turbo-run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run --dom --passWithNoTests",
    "check:type": "turbo run typecheck",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm -r run stub --if-present",
    "prepare": "is-ci || pnpm exec lefthook install"
  },
  "devDependencies": {
    "@ms/commitlint-config": "workspace:*",
    "@ms/eslint-config": "workspace:*",
    "@ms/node-utils": "workspace:*",
    "@ms/tsconfig": "workspace:*",
    "@ms/turbo-run": "workspace:*",
    "@ms/vite-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "catalog:",
    "lefthook": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  }
}
